# Supabase (crm-assistant project)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Meta WhatsApp Cloud API
# Get these from https://developers.facebook.com/apps → your WhatsApp Business app
META_PHONE_NUMBER_ID=        # WhatsApp → Configuration → Phone number ID
META_ACCESS_TOKEN=           # Permanent system user token (or temporary for testing)
META_APP_SECRET=             # App → Settings → Basic → App Secret
META_VERIFY_TOKEN=           # Any secret string you choose — must match webhook config in Meta dashboard
META_OWNER_ID=               # Supabase user ID (uuid) of the admin who "owns" incoming conversations

# App URL (used for webhook URL display in settings page)
NEXT_PUBLIC_APP_URL=
