# Firebase Web Config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_DATABASE_NAME=(default)

# Firebase Emulators (development only)
NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=
NEXT_PUBLIC_FIRESTORE_EMULATOR_HOST=
FUNCTIONS_EMULATOR=false

# Whapi.Cloud — WhatsApp integration
# Get your token at https://whapi.cloud → your channel → API Token
# WHAPI_API_TOKEN is server-side only (Cloud Functions), never expose in frontend
WHAPI_API_TOKEN=
